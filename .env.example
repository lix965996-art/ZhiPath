# Database
# Docker Compose default:
# DATABASE_URL=postgresql+asyncpg://zhipath:zhipath@postgres:5432/zhipath
#
# Local PostgreSQL example:
DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/zhipath

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Optional LLM providers.
# Prefer configuring real keys in the frontend Settings panel or deployment secrets.
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=
XF_SPARK_API_PASSWORD=

# Optional iFlytek TTS credentials.
XF_TTS_APPID=
XF_TTS_API_KEY=
XF_TTS_API_SECRET=
